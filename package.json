    "fix:encoding": "node scripts/fix-encoding.mjs"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "@webgpu/types": "^0.1.69",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
