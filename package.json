{
  "name": "arrival-logograms",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "predev": "npm run check:encoding",
    "build": "tsc --noEmit && vite build",
